# Postgres credentials for the synthetic-data StatefulSet.
# Copy to postgres.env (gitignored), fill real values, then run ./create-secrets.sh.
# These must match what 02-postgres.yaml expects and what synthetic-data.env's
# DATABASE_DEFAULT_USERNAME / DATABASE_DEFAULT_DATABASE point at.
POSTGRES_USER=synthetic_data_user
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=synthetic_data_main_db
